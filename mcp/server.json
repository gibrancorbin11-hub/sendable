{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "me.sendable/sendable",
  "description": "Send transactional email from your editor \u2014 describe the event, Sendable writes and sends it.",
  "status": "active",
  "version": "1.0.3",
  "websiteUrl": "https://www.sendable.me",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "sendableme-mcp",
      "version": "1.0.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SENDABLE_API_KEY",
          "description": "Your Sendable API key. Free at https://www.sendable.me/keys",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/gibrancorbin11-hub/sendable",
    "source": "github"
  }
}
